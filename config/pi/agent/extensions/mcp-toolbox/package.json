{
  "name": "pi-mcp-toolbox-extension",
  "version": "2.2.0",
  "private": true,
  "type": "module",
  "description": "Bounded MCP Toolbox dispatcher with managed dynamic 1Password database tools for Pi",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "check": "npm test && npm run syntax",
    "install-managed-runtime": "node scripts/install-managed-runtime.mjs",
    "syntax": "for file in src/*.ts test/*.test.ts; do node --experimental-strip-types --check \"$file\" || exit 1; done; node --check scripts/*.mjs",
    "test": "node --experimental-strip-types --test test/*.test.ts"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "@toolbox-sdk/core": "1.0.1",
    "axios": "1.18.1",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  }
}
